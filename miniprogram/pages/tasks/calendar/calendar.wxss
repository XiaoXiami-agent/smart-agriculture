/* 农事日历页面样式 */
page {
  min-height: 100vh;
  background: #f5f5f5;
}

.container {
  min-height: 100vh;
  padding: 20rpx 30rpx;
}

.status-bar {
  height: 60rpx;
}

.page-header {
  margin-bottom: 30rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
}

/* 日历区块 */
.calendar-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.calendar-header {
  margin-bottom: 30rpx;
}

.month-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.nav-btn {
  font-size: 36rpx;
  color: #4CAF50;
  padding: 15rpx 30rpx;
}

.month-label {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.calendar-week {
  display: flex;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 15rpx 0;
  margin-bottom: 15rpx;
}

.week-day {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #666;
}

.calendar-grid {
  display: flex;
  flex-direction: column;
}

.calendar-row {
  display: flex;
}

.calendar-cell {
  flex: 1;
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.cell-day {
  font-size: 30rpx;
  color: #333;
}

.calendar-cell.today {
  background: #E8F5E9;
  border-radius: 50%;
}

.calendar-cell.today .cell-day {
  color: #4CAF50;
  font-weight: 600;
}

.calendar-cell.has-task .cell-day {
  color: #4CAF50;
}

.task-dot {
  width: 10rpx;
  height: 10rpx;
  background: #4CAF50;
  border-radius: 50%;
  position: absolute;
  bottom: 15rpx;
}

/* 任务区块 */
.task-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
}

.section-header {
  margin-bottom: 25rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.task-item {
  display: flex;
  align-items: center;
  padding: 25rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
}

.task-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.task-info {
  flex: 1;
}

.task-name {
  font-size: 30rpx;
  color: #333;
  display: block;
  margin-bottom: 5rpx;
}

.task-crop {
  font-size: 24rpx;
  color: #999;
}

.task-status {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.task-status.done {
  background: #E8F5E9;
  color: #4CAF50;
}

.task-status.pending {
  background: #FFF8E1;
  color: #FFC107;
}

/* 空状态 */
.empty-task {
  text-align: center;
  padding: 60rpx;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
