/* 设置页面样式 */
page {
  min-height: 100vh;
  background: #f5f5f5;
}

.container {
  min-height: 100vh;
  padding: 20rpx 30rpx;
}

.status-bar {
  height: 60rpx;
}

.page-header {
  margin-bottom: 30rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
}

/* 设置区块 */
.settings-section {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 25rpx;
  overflow: hidden;
}

.section-title {
  font-size: 24rpx;
  color: #999;
  padding: 25rpx 30rpx 15rpx;
  background: #fafafa;
}

/* 设置项 */
.settings-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.settings-item:last-child {
  border-bottom: none;
}

.toggle-item {
  padding: 25rpx 30rpx;
}

.item-left {
  display: flex;
  align-items: center;
}

.item-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.item-content {
  display: flex;
  flex-direction: column;
}

.item-label {
  font-size: 30rpx;
  color: #333;
}

.item-value {
  font-size: 24rpx;
  color: #999;
  margin-top: 5rpx;
}

.item-arrow {
  color: #ccc;
  font-size: 28rpx;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 50rpx;
  color: #ccc;
  font-size: 24rpx;
}

.version-info text {
  display: block;
  margin-bottom: 10rpx;
}
