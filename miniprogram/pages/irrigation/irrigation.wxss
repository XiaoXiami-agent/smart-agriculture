/* 灌溉管理页面样式 */
page {
  min-height: 100vh;
  background: #f5f5f5;
}

.container {
  min-height: 100vh;
  padding: 20rpx 30rpx;
  padding-bottom: 120rpx;
}

.status-bar {
  height: 60rpx;
}

.page-header {
  margin-bottom: 30rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
}

/* 湿度概览 */
.humidity-overview {
  background: linear-gradient(135deg, #2196F3 0%, #03A9F4 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  color: #fff;
}

.overview-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.overview-icon {
  font-size: 70rpx;
  margin-right: 25rpx;
}

.overview-info {
  flex: 1;
}

.overview-title {
  font-size: 28rpx;
  opacity: 0.9;
  display: block;
  margin-bottom: 5rpx;
}

.overview-value {
  font-size: 60rpx;
  font-weight: 600;
}

.humidity-bar {
  height: 16rpx;
  background: rgba(255,255,255,0.3);
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.humidity-fill {
  height: 100%;
  background: #fff;
  border-radius: 8rpx;
}

.humidity-tips {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.tip-item {
  font-size: 26rpx;
  padding: 10rpx 15rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 8rpx;
}

/* 作物列表 */
.crop-list {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 25rpx;
}

.crop-item {
  padding: 25rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.crop-item:last-child {
  margin-bottom: 0;
}

.crop-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.crop-icon {
  font-size: 50rpx;
  margin-right: 15rpx;
}

.crop-info {
  flex: 1;
}

.crop-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 5rpx;
}

.crop-stage {
  font-size: 24rpx;
  color: #999;
}

.humidity-status {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.humidity-status.normal {
  background: #E8F5E9;
  color: #4CAF50;
}

.humidity-status.low {
  background: #FFF8E1;
  color: #FFC107;
}

.humidity-status.high {
  background: #E3F2FD;
  color: #2196F3;
}

.humidity-progress {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
}

.progress-bar {
  flex: 1;
  height: 12rpx;
  background: #e0e0e0;
  border-radius: 6rpx;
  margin-right: 15rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.3s;
}

.progress-fill.normal {
  background: #4CAF50;
}

.progress-fill.low {
  background: #FFC107;
}

.progress-fill.high {
  background: #2196F3;
}

.progress-value {
  font-size: 26rpx;
  color: #666;
  min-width: 80rpx;
  text-align: right;
}

.irrigation-tip {
  font-size: 24rpx;
  color: #666;
  padding: 10rpx 15rpx;
  background: #fff;
  border-radius: 8rpx;
}

/* 建议卡片 */
.advice-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.advice-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.advice-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
}

.advice-icon {
  font-size: 32rpx;
  margin-right: 15rpx;
}

.advice-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

/* 快速操作按钮 */
.quick-actions {
  position: fixed;
  bottom: 30rpx;
  left: 30rpx;
  right: 30rpx;
  display: flex;
  gap: 20rpx;
  z-index: 10;
}

.action-btn {
  flex: 1;
  background: #fff;
  border-radius: 50rpx;
  padding: 25rpx 30rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
}

.action-btn.primary {
  background: linear-gradient(135deg, #2196F3 0%, #03A9F4 100%);
  color: #fff;
}

.action-btn text {
  font-size: 28rpx;
}

/* ==================== 历史记录弹窗样式 ==================== */
.history-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.history-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
}

.history-content {
  position: relative;
  width: 100%;
  max-height: 85vh;
  background: #f5f5f5;
  border-radius: 30rpx 30rpx 0 0;
  padding: 30rpx;
  overflow-y: auto;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.history-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.history-close {
  width: 60rpx;
  height: 60rpx;
  background: #eee;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
}

/* 历史概览 */
.history-overview {
  display: flex;
  justify-content: space-between;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  margin-bottom: 30rpx;
  overflow-x: auto;
}

.overview-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 80rpx;
}

.overview-date {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 15rpx;
}

.overview-date text:first-child {
  font-size: 24rpx;
  color: #666;
}

.overview-date.today text:first-child {
  color: #2196F3;
  font-weight: 600;
}

.date-str {
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}

.overview-chart {
  height: 80rpx;
  display: flex;
  align-items: flex-end;
  margin-bottom: 10rpx;
}

.chart-bar {
  width: 30rpx;
  background: linear-gradient(180deg, #4CAF50 0%, #81C784 100%);
  border-radius: 6rpx 6rpx 0 0;
  min-height: 10rpx;
}

.overview-value {
  font-size: 24rpx;
  font-weight: 600;
}

.overview-value.normal {
  color: #4CAF50;
}

.overview-value.low {
  color: #FFC107;
}

.overview-value.high {
  color: #2196F3;
}

/* 详细记录 */
.history-detail {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.detail-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 25rpx;
}

.detail-list {
  display: flex;
  flex-direction: column;
  gap: 25rpx;
}

.detail-item {
  display: flex;
  gap: 20rpx;
}

.detail-date {
  width: 100rpx;
  font-size: 24rpx;
  color: #666;
  text-align: center;
}

.detail-date.today {
  color: #2196F3;
  font-weight: 600;
}

.detail-records {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.record-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.record-crop {
  width: 60rpx;
  font-size: 22rpx;
  color: #666;
}

.record-bar-wrap {
  flex: 1;
  height: 16rpx;
  background: #eee;
  border-radius: 8rpx;
  overflow: hidden;
}

.record-bar {
  height: 100%;
  background: #4CAF50;
  border-radius: 8rpx;
}

.record-value {
  width: 70rpx;
  font-size: 22rpx;
  color: #333;
  text-align: right;
}

.record-change {
  width: 60rpx;
  font-size: 20rpx;
  color: #999;
  text-align: right;
}

.record-change.up {
  color: #F44336;
}

.record-change.down {
  color: #4CAF50;
}

/* 操作按钮 */
.history-actions {
  padding: 20rpx 0;
}

.action-export {
  background: linear-gradient(135deg, #2196F3 0%, #03A9F4 100%);
  color: #fff;
  border-radius: 50rpx;
  padding: 25rpx;
  text-align: center;
}

.action-export text {
  font-size: 28rpx;
}

.action-close {
  background: #fff;
  border-radius: 50rpx;
  padding: 25rpx;
  text-align: center;
}

.action-close text {
  font-size: 28rpx;
  color: #666;
}

/* ==================== 作物趋势图样式 ==================== */
.trend-chart {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.trend-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 25rpx;
}

.trend-container {
  padding: 20rpx 0;
}

.trend-bars {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  height: 200rpx;
  padding: 0 10rpx;
  margin-bottom: 15rpx;
}

.trend-bar-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.trend-bar {
  width: 40rpx;
  border-radius: 8rpx 8rpx 0 0;
  margin-bottom: 10rpx;
}

.trend-value {
  font-size: 20rpx;
  color: #666;
}

.trend-labels {
  display: flex;
  justify-content: space-between;
  padding: 0 10rpx;
}

.trend-labels text {
  flex: 1;
  text-align: center;
  font-size: 20rpx;
  color: #999;
}

/* 作物统计 */
.crop-stats {
  display: flex;
  justify-content: space-around;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.stat-value.normal {
  color: #4CAF50;
}

.stat-value.low {
  color: #FFC107;
}

.stat-value.high {
  color: #2196F3;
}

.stat-value.up {
  color: #F44336;
}

.stat-value.down {
  color: #4CAF50;
}
