/* 作物列表样式 */
page {
  min-height: 100vh;
  background: #f5f5f5;
}

.container {
  min-height: 100vh;
  padding: 20rpx 30rpx;
}

.status-bar {
  height: 60rpx;
}

/* 页面头部 */
.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
}

.add-btn {
  background: #4CAF50;
  color: #fff;
  padding: 16rpx 30rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
}

/* 作物卡片 */
.crop-list {
  display: flex;
  flex-direction: column;
  gap: 25rpx;
}

.crop-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.crop-header {
  display: flex;
  align-items: center;
  margin-bottom: 25rpx;
}

.crop-icon {
  font-size: 60rpx;
  margin-right: 20rpx;
}

.crop-info {
  flex: 1;
}

.crop-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.crop-variety {
  font-size: 26rpx;
  color: #999;
}

.crop-status {
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.crop-status.normal {
  background: #E8F5E9;
  color: #4CAF50;
}

.crop-status.warning {
  background: #FFF8E1;
  color: #FFC107;
}

.crop-status.danger {
  background: #FFEBEE;
  color: #F44336;
}

.crop-body {
  display: flex;
  justify-content: space-between;
  padding: 25rpx 0;
  border-top: 1rpx solid #f0f0f0;
  border-bottom: 1rpx solid #f0f0f0;
}

.crop-stage, .crop-date {
  text-align: center;
  flex: 1;
}

.stage-label, .date-label {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 10rpx;
}

.stage-value, .date-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.crop-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}

.crop-days {
  font-size: 26rpx;
  color: #666;
}

.crop-arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 50rpx;
}

.empty-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  display: block;
  margin-bottom: 15rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 50rpx;
}

.empty-btn {
  background: #4CAF50;
  color: #fff;
  padding: 25rpx 60rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  display: inline-block;
}

/* 加载动画 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 99;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid rgba(255,255,255,0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
