<!-- 作物详情页面 -->
<view class="container">
  <!-- 状态栏占位 -->
  <view class="status-bar"></view>
  
  <!-- 返回按钮 -->
  <view class="back-btn" bindtap="goBack">
    <text>← 返回</text>
  </view>
  
  <!-- 作物信息卡片 -->
  <view class="crop-info-card" wx:if="{{crop}}">
    <view class="crop-header">
      <text class="crop-icon">{{crop.icon}}</text>
      <view class="crop-title">
        <text class="crop-name">{{crop.name}}</text>
        <text class="crop-variety">{{crop.variety}}</text>
      </view>
      <view class="crop-status {{crop.status}}">
        <text>{{crop.statusText}}</text>
      </view>
    </view>
    
    <view class="crop-stats">
      <view class="stat-item">
        <text class="stat-value">{{crop.days}}</text>
        <text class="stat-label">种植天数</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{crop.stage}}</text>
        <text class="stat-label">当前阶段</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{crop.tasks || 0}}</text>
        <text class="stat-label">待办任务</text>
      </view>
    </view>
  </view>
  
  <!-- 基础信息 -->
  <view class="info-section">
    <view class="section-title">基本信息</view>
    <view class="info-list">
      <view class="info-item">
        <text class="info-label">种植日期</text>
        <text class="info-value">{{crop.plantDate}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">预期收获</text>
        <text class="info-value">{{crop.expectedHarvest || '未设置'}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">创建时间</text>
        <text class="info-value">{{crop.createTimeStr}}</text>
      </view>
    </view>
  </view>
  
  <!-- 备注信息 -->
  <view class="info-section" wx:if="{{crop.notes}}">
    <view class="section-title">备注</view>
    <view class="notes-content">
      <text>{{crop.notes}}</text>
    </view>
  </view>
  
  <!-- 操作按钮 -->
  <view class="action-buttons">
    <view class="action-btn edit-btn" bindtap="editCrop">
      <text>编辑</text>
    </view>
    <view class="action-btn delete-btn" bindtap="deleteCrop">
      <text>删除</text>
    </view>
  </view>
</view>
